# FreeAI — переменные окружения
# Скопируйте этот файл в .env: cp .env.example .env
# Затем заполните значения и запустите: python api.py

# Обязательно: секрет для Flask-сессий (длинная случайная строка)
SESSION_SECRET=change-me-to-a-long-random-string-min-32-chars

# Путь к файлу базы данных SQLite
DATABASE_PATH=database.db

# Хост и порт для запуска сервера
HOST=0.0.0.0
PORT=5000

# Username Telegram-бота (без @)
SAM_BOT_USERNAME=SamGPTrobot

# Максимальное время ожидания ответа от ИИ (секунды, дефолт 600 = 10 минут)
REQUEST_TIMEOUT_SECONDS=600

# Время тишины бота для сбора частей ответа (секунды, дефолт 3.0)
# Увеличьте если бот пишет ответ с паузами > 3 секунд между частями
BOT_QUIET_SECONDS=3.0

# Telegram-уведомления о новых ссылках Cloudflare
# Токен бота для отправки уведомлений
TG_NOTIFY_TOKEN=
# ID чатов/каналов через запятую (для каналов: -100XXXXXXXXXX или @username)
TG_NOTIFY_CHATS=
